<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/dark_gray"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Header with Hamburger Menu -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="@color/medium_gray">

        <TextView
            android:text="Reports"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/yellow_accent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"/>

        <!-- Hamburger Menu Button -->
        <ImageButton
            android:id="@+id/menuButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/baseline_settings_24"
            app:tint="@color/yellow_accent" />
    </RelativeLayout>

    <!-- Dropdown Menu (Initially Hidden) -->
    <LinearLayout
        android:id="@+id/dropdownMenu"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="16dp"
        android:background="@color/light_gray"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Settings"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/yellow_accent"
            android:layout_marginBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Currency: ZAR"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:paddingVertical="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <View android:background="@color/text_secondary" android:layout_width="match_parent" android:layout_height="1dp"/>

        <TextView
            android:text="Country: South Africa"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:paddingVertical="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <View android:background="@color/text_secondary" android:layout_width="match_parent" android:layout_height="1dp"/>

        <TextView
            android:text="Language: English"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:paddingVertical="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <View android:background="@color/text_secondary" android:layout_width="match_parent" android:layout_height="1dp"/>

        <TextView
            android:text="Personal Information"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:paddingVertical="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Circular Chart -->
    <LinearLayout
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/circular_chart"
            android:layout_width="180dp"
            android:layout_height="180dp">

            <TextView
                android:text="R5,229"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/yellow_accent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView
            android:text="Income vs Expenses"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Summary Cards -->
    <LinearLayout
        android:orientation="horizontal"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@color/light_gray"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <TextView
                android:text="Total Income"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="R8,000"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/income_green"
                android:layout_marginTop="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@color/light_gray"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <TextView
                android:text="Total Expenses"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="R2,771"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/expense_red"
                android:layout_marginTop="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Category Breakdown (No Icons) -->
    <TextView
        android:text="Category Breakdown"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:padding="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <LinearLayout
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:orientation="horizontal"
            android:paddingVertical="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Groceries"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="R200"
                android:textSize="16sp"
                android:textColor="@color/expense_red"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <View android:background="@color/light_gray" android:layout_width="match_parent" android:layout_height="1dp"/>

        <LinearLayout
            android:orientation="horizontal"
            android:paddingVertical="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Fuel"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="R300"
                android:textSize="16sp"
                android:textColor="@color/expense_red"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <View android:background="@color/light_gray" android:layout_width="match_parent" android:layout_height="1dp"/>

        <LinearLayout
            android:orientation="horizontal"
            android:paddingVertical="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Dining"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="R50"
                android:textSize="16sp"
                android:textColor="@color/expense_red"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Navigation Bar -->
    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center_vertical|center_horizontal"
        android:padding="16dp"
        android:background="@color/medium_gray"
        android:elevation="8dp"
        android:layout_width="match_parent"
        android:layout_height="80dp">

        <ImageButton
            android:id="@+id/navHome"
            android:src="@drawable/baseline_house_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/text_secondary"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="40dp"/>

        <ImageButton
            android:id="@+id/navHistory"
            android:src="@android:drawable/ic_menu_recent_history"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/text_secondary"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="40dp"/>

        <ImageButton
            android:id="@+id/navReports"
            android:src="@drawable/baseline_poll_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/yellow_accent"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="40dp"/>

        <ImageButton
            android:id="@+id/navProfile"
            android:src="@drawable/baseline_person_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/text_secondary"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="40dp"/>
    </LinearLayout>

</LinearLayout>